# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=your_super_secret_key_here

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS — укажи URL своего Vercel-фронтенда, через запятую если несколько
# Пример: https://your-app.vercel.app,https://your-custom-domain.kz
ALLOWED_ORIGINS=https://your-app.vercel.app
